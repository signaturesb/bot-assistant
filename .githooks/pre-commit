#!/bin/bash
# Pre-commit hook — valide bot.js avant commit
# Installé via: git config core.hooksPath .githooks
cd "$(git rev-parse --show-toplevel)"
if [ -f validate.js ]; then
  node validate.js || {
    echo ""
    echo "❌ COMMIT BLOQUÉ — corriger les erreurs ci-dessus"
    echo "   Pour bypass (dangereux): git commit --no-verify"
    exit 1
  }
fi
