{
  "name": "kira-telegram-bot",
  "version": "1.0.0",
  "description": "Kira — assistante IA de Shawn via Telegram",
  "main": "bot.js",
  "scripts": {
    "start": "node bot.js",
    "validate": "node validate.js",
    "diagnose": "node diagnose.js",
    "fix": "node fix.js",
    "sync-env": "node scripts/sync-env-render.js",
    "sync-env:dry": "node scripts/sync-env-render.js --dry-run",
    "enable-security": "node scripts/enable-github-security.js",
    "security-status": "node scripts/security-status.js",
    "doctor": "node scripts/doctor.js",
    "audit-history": "bash scripts/audit-history.sh",
    "test": "node test_all.js",
    "test-smoke": "node test_all.js --smoke",
    "test-parser": "node test_parser.js",
    "test-firecrawl": "node test_firecrawl.js",
    "test-cua": "node test_cua.js",
    "preflight": "npm run validate && npm run security-status"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.98.0",
    "@xenova/transformers": "^2.17.2",
    "better-sqlite3": "^12.10.0",
    "cheerio": "^1.2.0",
    "compression": "^1.8.1",
    "dotenv": "^16.0.0",
    "fuse.js": "^7.3.0",
    "got": "^15.0.5",
    "helmet": "^8.2.0",
    "lru-cache": "^11.5.0",
    "node-telegram-bot-api": "^0.67.0",
    "otpauth": "^9.5.1",
    "p-limit": "^7.3.0",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5",
    "playwright-core": "^1.60.0",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "rebrowser-playwright": "^1.52.0",
    "zod": "^4.4.3"
  },
  "overrides": {
    "form-data": "^4.0.4",
    "qs": "^6.14.1",
    "tough-cookie": "^4.1.3",
    "uuid": "^14.0.0"
  }
}
